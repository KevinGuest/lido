# bitcoin node running in your private network 192.168.1.0/24
BITCOIN_RPC_URL=http://192.168.1.100

# bitcoin node running undockered on the same PC
# needs to add rpcallowip=172.16.0.0/12 to your bitcoin.conf
#BITCOIN_RPC_URL=http://host.docker.internal

BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_TIMEOUT=10000

# You can use this instead of BITCOIN_RPC_USER and BITCOIN_RPC_PASSWORD
BITCOIN_RPC_COOKIEFILE=

# Enable in bitcoin.conf with
# zmqpubrawblock=tcp://*:3000
# BITCOIN_ZMQ_HOST="tcp://192.168.1.100:3000"

# HTTP API (proxied with the UI on :3000 under Umbrel; direct local default below)
API_PORT=2019
STRATUM_PORT=3333
STRATUM_MAX_CONNECTIONS_PER_LISTENER=10000

# Stratum V2 (dual-stack add-on; V1 stays on STRATUM_PORT)
# ENABLE_STRATUM_V2=true
# STRATUM_V2_PORT=4444
# Optional fixed authority key (64 hex chars). If unset, Lido generates one and
# persists it under DB/sv2-authority.privkey so restarts and image updates keep
# the same pubkey. Refresh from the Connect UI only when you want a new key.
# SV2_AUTHORITY_PRIVKEY=
# Optional starting share difficulty / target share rate for SV2 channels
# SV2_START_DIFFICULTY=100000
# SV2_TARGET_SHARES_PER_MINUTE=2

#optional telegram bot
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=

#optional discord bot
#DISCORD_BOT_TOKEN=
#DISCORD_BOT_CLIENTID=
#DISCORD_BOT_GUILD_ID=
#DISCORD_BOT_CHANNEL_ID=

#optional
DEV_FEE_ADDRESS=
# mainnet | testnet
NETWORK=mainnet

API_SECURE=false
# Default is "Public-Pool", you can change it to any string it will be removed if it will make the block or coinbase script too big
POOL_IDENTIFIER="Public-Pool"
